# .env.example — copy this to .env and fill in your real values
# NEVER commit .env to git — it contains secrets

# ── Database mode ────────────────────────────────────────────────
# 'mock'     → local JSON file (no AWS needed)
# 'dynamodb' → real AWS DynamoDB
DB_TYPE=dynamodb

# ── AWS credentials ──────────────────────────────────────────────
# Get these from IAM → Users → Security credentials → Create access key
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE

# ── DynamoDB ─────────────────────────────────────────────────────
# Table must exist in your AWS account with partition key: media_id (String)
DYNAMODB_TABLE_NAME=MediaMetadata

# ── S3 / SQS (optional — leave as-is if not using real S3 yet) ──
S3_BUCKET=media-sharing-bucket
SQS_QUEUE_NAME=media-processing-queue
